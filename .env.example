# LLM Configuration
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.moonshot.cn/v1
LLM_MODEL_NAME=kimi-latest
LLM_TEMPERATURE_CHAT=0.7
LLM_TEMPERATURE_DIAGNOSIS=0.2
LLM_TEMPERATURE_PEDAGOGY=0.6
LLM_MAX_TOKENS=2048
LLM_TIMEOUT=30.0

# Memory Configuration
MEM_STORAGE_PATH=./data/memory
MEM_ACTIVATION_DECAY=0.9
MEM_ACTIVATION_BOOST=0.25
MEM_STABILIZATION_THRESHOLD=0.85
MEM_WORKING_MEMORY_CAPACITY=7

# Diagnostic Configuration
DIAG_SPACY_MODEL=en_core_web_sm
DIAG_FALLBACK_ENABLED=true
DIAG_SYSTEMATIC_ERROR_THRESHOLD=2
