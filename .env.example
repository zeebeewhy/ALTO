# ALTO — Adaptive Learning Tutor Orchestrator
# Configuration file: .env 或环境变量
#
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  ⚠️  重要：Kimi Code API 和 Moonshot Open Platform 是两个独立体系！
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#
# Kimi Code API（推荐，如果你有订阅）
#   - 端点: https://api.kimi.com/coding/v1
#   - 获取: https://www.kimi.com/code/console （Kimi 会员权益）
#   - Key格式: sk-kimi-xxxxxxxx
#   - 模型: kimi-for-coding
#   - 说明: 这是Kimi Code订阅的API，通过会员套餐获得额度
#
# Moonshot Open Platform（按量计费）
#   - 端点: https://api.moonshot.cn/v1
#   - 获取: https://platform.moonshot.cn （需单独充值）
#   - Key格式: sk-xxxxxxxx
#   - 模型: kimi-latest, kimi-k2.6
#   - 说明: 通用的开放平台，与Kimi Code额度不互通
#
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ═══════════════════════════════════════════════════════════════
# 方式一：Kimi Code API（如果你有Kimi Code订阅/会员）
# ═══════════════════════════════════════════════════════════════
# 取消下面两行的注释，填入你的Kimi Code API Key：
#
# KIMI_CODE_API_KEY=sk-kimi-your-key-here
# KIMI_CODE_BASE_URL=https://api.kimi.com/coding/v1
#
# 模型名称（Kimi Code固定使用这个ID，后端自动映射到最新模型）：
# KIMI_CODE_MODEL_NAME=kimi-for-coding

# ═══════════════════════════════════════════════════════════════
# 方式二：Moonshot Open Platform（如果你有Open Platform额度）
# ═══════════════════════════════════════════════════════════════
# MOONSHOT_API_KEY=sk-your-moonshot-key
# MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
# MOONSHOT_MODEL_NAME=kimi-latest

# ═══════════════════════════════════════════════════════════════
# 方式三：OpenAI / DeepSeek / OpenRouter / 其他兼容端点
# ═══════════════════════════════════════════════════════════════
# OPENAI_API_KEY=sk-your-key
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL_NAME=gpt-4o
#
# DeepSeek示例:
# OPENAI_API_KEY=sk-your-deepseek-key
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# OPENAI_MODEL_NAME=deepseek-chat

# ═══════════════════════════════════════════════════════════════
# 方式四：ALTO专用变量名（覆盖以上所有）
# ═══════════════════════════════════════════════════════════════
# 如果你不想用上述标准变量名，可以用ALTO自己的：
# LLM_API_KEY=sk-your-key
# LLM_BASE_URL=https://api.kimi.com/coding/v1
# LLM_MODEL_NAME=kimi-for-coding

# ═══════════════════════════════════════════════════════════════
# 生成参数（一般不需要改）
# ═══════════════════════════════════════════════════════════════
LLM_TEMPERATURE_CHAT=0.7
LLM_TEMPERATURE_DIAGNOSIS=0.2
LLM_TEMPERATURE_PEDAGOGY=0.6
LLM_MAX_TOKENS=2048
LLM_TIMEOUT=30.0

# ═══════════════════════════════════════════════════════════════
# 记忆系统
# ═══════════════════════════════════════════════════════════════
MEM_STORAGE_PATH=./data/memory
MEM_ACTIVATION_DECAY=0.9
MEM_ACTIVATION_BOOST=0.25
MEM_STABILIZATION_THRESHOLD=0.85
MEM_WORKING_MEMORY_CAPACITY=7

# ═══════════════════════════════════════════════════════════════
# 诊断层
# ═══════════════════════════════════════════════════════════════
DIAG_SPACY_MODEL=en_core_web_sm
DIAG_FALLBACK_ENABLED=true
DIAG_SYSTEMATIC_ERROR_THRESHOLD=2
